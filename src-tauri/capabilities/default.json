{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "默认权限:主窗口 + 浮窗。core:default 已包含常用 webview/window 控制",
  "windows": ["main", "floating"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-load",
    "sql:allow-select",
    "sql:allow-close"
  ]
}
