{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Daybreak",
  "version": "0.1.0",
  "identifier": "com.daybreak.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Daybreak",
        "width": 1100,
        "height": 740,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "alwaysOnTop": false,
        "center": true
      },
      {
        "label": "floating",
        "title": "Daybreak",
        "url": "/index.html#/__floating__",
        "width": 260,
        "height": 420,
        "minWidth": 240,
        "minHeight": 360,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "visible": false,
        "transparent": true,
        "shadow": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
